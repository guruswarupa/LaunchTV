#!/bin/bash
set -e

INSTALL_DIR="/opt/linuxtv"
LINUXTV_USER="linuxtv"

if ! id -u "$LINUXTV_USER" >/dev/null 2>&1; then
  useradd -m -s /bin/bash -G sudo,video,audio,input,plugdev,netdev "$LINUXTV_USER"
  echo "${LINUXTV_USER}:linuxtv" | chpasswd
fi

# Add user to backlight group for brightness control (if group exists)
groupadd -f backlight 2>/dev/null || true
usermod -aG backlight "$LINUXTV_USER" 2>/dev/null || true

install -d -m 0755 /etc/polkit-1/rules.d
cat > /etc/polkit-1/rules.d/49-linuxtv-networkmanager.rules <<'EOF'
polkit.addRule(function(action, subject) {
  if (subject.local &&
      subject.active &&
      subject.isInGroup("netdev")) {
    if (action.id.indexOf("org.freedesktop.NetworkManager.") === 0 ||
        action.id.indexOf("org.freedesktop.timedate1.") === 0) {
      return polkit.Result.YES;
    }
  }
});
EOF
chmod 0644 /etc/polkit-1/rules.d/49-linuxtv-networkmanager.rules

# Create udev rule for brightness control access
install -d -m 0755 /etc/udev/rules.d
cat > /etc/udev/rules.d/81-linuxtv-backlight.rules <<'EOF'
ACTION=="add", SUBSYSTEM=="backlight", RUN+="/bin/chmod 666 /sys/class/backlight/%k/brightness"
ACTION=="add", SUBSYSTEM=="leds", RUN+="/bin/chmod 666 /sys/class/leds/%k/brightness"
EOF
chmod 0644 /etc/udev/rules.d/81-linuxtv-backlight.rules
systemctl enable systemd-timesyncd 2>/dev/null || true

VENV_DIR="/opt/linuxtv/.venv"

apt-get install -y wget libmpv-dev python3-yaml python3-websockets python3-evdev ca-certificates gnupg
python3 -m venv --system-site-packages "$VENV_DIR"
"$VENV_DIR/bin/pip" install --upgrade pip setuptools wheel

# Install Brave browser manually to ensure GPG key is properly set up
if [ ! -f /usr/share/keyrings/brave-browser-archive-keyring.gpg ]; then
  install -d -m 0755 /etc/apt/keyrings
  curl -fsSLo /etc/apt/keyrings/brave-browser-archive-keyring.gpg https://brave-browser-apt-release.s3.brave.com/brave-browser-archive-keyring.gpg
  echo "deb [signed-by=/etc/apt/keyrings/brave-browser-archive-keyring.gpg arch=amd64] https://brave-browser-apt-release.s3.brave.com/ stable main" > /etc/apt/sources.list.d/brave-browser-release.list
  apt-get update
fi
apt-get install -y brave-browser

# Install Stremio from custom repository
wget -qO - https://debian.vejeta.com/key.gpg | gpg --dearmor -o /usr/share/keyrings/stremio-debian.gpg
echo "deb [signed-by=/usr/share/keyrings/stremio-debian.gpg] https://debian.vejeta.com trixie main non-free" > /etc/apt/sources.list.d/stremio.list
apt-get update
apt-get install -y stremio stremio-server

chown -R "${LINUXTV_USER}:${LINUXTV_USER}" "$INSTALL_DIR"
chown -R "${LINUXTV_USER}:${LINUXTV_USER}" "$VENV_DIR"

# Ensure icons are readable by all users
chmod -R o+r "$INSTALL_DIR/linuxtvdesktop/icons/"

ln -sfn "$VENV_DIR" "/home/${LINUXTV_USER}/.linuxtv_venv"
chown -h "${LINUXTV_USER}:${LINUXTV_USER}" "/home/${LINUXTV_USER}/.linuxtv_venv"

cat > "/home/${LINUXTV_USER}/.xinitrc" <<'XINITRC'
#!/bin/sh
export PATH="/opt/linuxtv/.venv/bin:$PATH"
export LINUXTV_QT_BINDING=PyQt5
export XDG_RUNTIME_DIR="/run/user/$(id -u)"
export DBUS_SESSION_BUS_ADDRESS="unix:path=$XDG_RUNTIME_DIR/bus"

exec > /tmp/linuxtv_startup.log 2>&1

if [ ! -S "$XDG_RUNTIME_DIR/bus" ] && command -v dbus-daemon >/dev/null 2>&1; then
  dbus-daemon --session --address="$DBUS_SESSION_BUS_ADDRESS" --fork || true
fi

if command -v systemctl >/dev/null 2>&1; then
  systemctl --user import-environment DISPLAY XAUTHORITY XDG_RUNTIME_DIR DBUS_SESSION_BUS_ADDRESS 2>/dev/null || true
  systemctl --user start pulseaudio.service 2>/dev/null || true
fi

if command -v xrandr >/dev/null 2>&1; then
  HDMI_OUTPUT=$(xrandr --query | awk '/^HDMI[^ ]* connected/{print $1; exit}')
  INTERNAL_OUTPUT=$(xrandr --query | awk '/^(eDP|LVDS)[^ ]* connected/{print $1; exit}')
  if [ -n "$HDMI_OUTPUT" ]; then
    if [ -n "$INTERNAL_OUTPUT" ]; then
      xrandr --output "$HDMI_OUTPUT" --auto --primary --output "$INTERNAL_OUTPUT" --off || true
    else
      xrandr --output "$HDMI_OUTPUT" --auto --primary || true
    fi
  fi
fi

if command -v openbox >/dev/null 2>&1; then
  openbox &
  sleep 0.5
fi

cd /opt/linuxtv/linuxtvdesktop
exec /opt/linuxtv/.venv/bin/python3 /opt/linuxtv/linuxtvdesktop/launcher.py
XINITRC
chmod +x "/home/${LINUXTV_USER}/.xinitrc"
chown "${LINUXTV_USER}:${LINUXTV_USER}" "/home/${LINUXTV_USER}/.xinitrc"

mkdir -p "/home/${LINUXTV_USER}/.config/linuxtv"
cp "$INSTALL_DIR/linuxtvdesktop/config.yaml" "/home/${LINUXTV_USER}/.config/linuxtv/config.yaml" 2>/dev/null || true
chown -R "${LINUXTV_USER}:${LINUXTV_USER}" "/home/${LINUXTV_USER}/.config"

# Configure Plymouth splash theme
if command -v plymouth-set-default-theme >/dev/null 2>&1; then
  plymouth-set-default-theme -R linuxtv || true
fi

mkdir -p /etc/systemd/system/getty@.service.d
cat > /etc/systemd/system/getty@.service.d/override.conf <<EOF
[Service]
ExecStart=
ExecStart=-/sbin/agetty --autologin ${LINUXTV_USER} --noclear %I \$TERM
EOF

cat >> "/home/${LINUXTV_USER}/.profile" <<'PROFILE'

if [ -z "$DISPLAY" ] && [ "$(tty)" = "/dev/tty1" ]; then
  STARTUP_COUNT=${STARTUP_COUNT:-0}
  export STARTUP_COUNT=$((STARTUP_COUNT + 1))
  if [ $STARTUP_COUNT -gt 3 ]; then
    echo "LinuxTV startup failed multiple times."
    echo "Debug: cat /tmp/linuxtv_startup.log"
  else
    exec startx
  fi
fi
PROFILE
chown "${LINUXTV_USER}:${LINUXTV_USER}" "/home/${LINUXTV_USER}/.profile"

for dm in gdm3 lightdm sddm; do
  systemctl disable "$dm" 2>/dev/null || true
done
